# REDIRECTION HTTP → HTTPS
server {
    if ($host = api.mirbda.io) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    listen 80;
    server_name api.mirbda.io;

    # Redirect all HTTP to HTTPS
    return 301 https://$host$request_uri;


}

# HTTPS BLOCK
server {
    listen 443 ssl http2;
    server_name api.mirbda.io;
    ssl_certificate /etc/letsencrypt/live/api.mirbda.io/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/api.mirbda.io/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    # Gzip compression
    gzip on;
    gzip_types application/json text/plain;
    gzip_min_length 1024;
    gzip_comp_level 6;

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "no-referrer-when-downgrade" always;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;

    location / {
        proxy_pass http://localhost:7777;  # Docker container
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
    }

}
